# ─── Avoxi ────────────────────────────────────────────────────────────────
# Long-lived bearer token with CDR read scope.
AVOXI_API_TOKEN=eyJ...
AVOXI_BASE_URL=https://genius.avoxi.com/api/v2

# ─── LLM (OpenAI-wire compatible) ────────────────────────────────────────
# One of: kimi | openai | gemini
LLM_PROVIDER=kimi
LLM_API_KEY=sk-...
LLM_MODEL=moonshot-v1-32k
# Override only if the provider's OpenAI-compatible endpoint is non-default:
# LLM_BASE_URL=https://api.moonshot.cn/v1

# ─── Identity ────────────────────────────────────────────────────────────
COMPANY_NAME=Grupo Wellness
