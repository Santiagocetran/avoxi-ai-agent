# ─── LLM Provider ────────────────────────────────────────────────────────────
# Choose one: "kimi" | "hermes"
LLM_PROVIDER=kimi

# Kimi (Moonshot AI) — https://platform.moonshot.cn
KIMI_API_KEY=sk-...
KIMI_MODEL=moonshot-v1-32k
# KIMI_BASE_URL=https://api.moonshot.cn/v1   # default, override if needed

# Hermes local via Ollama — run: ollama serve && ollama pull hermes3
# HERMES_BASE_URL=http://localhost:11434/v1
# HERMES_MODEL=hermes3

# ─── AVOXI API ────────────────────────────────────────────────────────────────
# Admin API key from: AVOXI Dashboard → Settings → API Access
AVOXI_API_KEY=your-avoxi-api-key-here
AVOXI_BASE_URL=https://api.avoxi.com/v2
AVOXI_ACCOUNT_ID=your-account-id

# ─── Monitoring ──────────────────────────────────────────────────────────────
# Cron schedule for the background monitor (default: every 5 minutes)
MONITOR_CRON=*/5 * * * *

# Failure rate threshold to trigger a CRITICAL alert (percent)
FAILURE_RATE_CRITICAL=40

# Failure rate threshold to trigger a WARNING alert (percent)
FAILURE_RATE_WARNING=15

# Short call rate threshold (calls < 10s, percent)
SHORT_CALL_WARNING=20

# Minimum calls in a window before anomaly detection kicks in
MIN_CALLS_FOR_DETECTION=5

# ─── Notifications (optional) ─────────────────────────────────────────────────
# Slack webhook URL to post alerts
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Email address to send critical alerts to (requires SMTP config below)
# ALERT_EMAIL=ops@grupowellnesslatina.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
