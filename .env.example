# ─── Avoxi API ────────────────────────────────────────────────────────────
# See docs/AVOXI-API.md. Token is a long-lived bearer; grant it scope for
# CDRs, agents, alerts, live, numbers.
AVOXI_API_TOKEN=eyJ...                                   # required
AVOXI_BASE_URL=https://genius.avoxi.com/api/v2
# AVOXI_DEFAULT_TEAM_ID=                                 # optional; used by cli/watch
# AVOXI_TIMEZONE=America/Argentina/Buenos_Aires          # query-param timezone for /cdrs

# ─── LLM Provider ────────────────────────────────────────────────────────
# Choose one: "kimi" | "openai" | "gemini" | "claude"
LLM_PROVIDER=kimi

# Kimi (Moonshot AI)
KIMI_API_KEY=sk-...
KIMI_MODEL=moonshot-v1-32k
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Google Gemini
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash

# Anthropic Claude
# CLAUDE_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-6

# ─── Identity ────────────────────────────────────────────────────────────
COMPANY_NAME=Grupo Wellness

# ─── Schedule ─────────────────────────────────────────────────────────────
# The declarative source of truth is config/schedule.yaml.
# Point to an alternate file for multiple deployments:
# SCHEDULE_FILE=config/schedule.yaml

# ─── Privacy / recordings ────────────────────────────────────────────────
# The declarative source of truth is config/privacy.yaml.
# Toggles below override the YAML if set, for quick experimentation.
# RECORDINGS_ENABLED=false
# TRANSCRIPTION_ENABLED=false
# TRANSCRIPTION_PROVIDER=                                # openai-whisper|gemini|local-whisper
# TRANSCRIPTION_API_KEY=
# RECORDING_SCRATCH_DIR=./tmp/recordings
# RECORDING_RETENTION_DAYS=7

# ─── Watch daemon (cli/watch) ────────────────────────────────────────────
# Cron cadence during on-call windows.
WATCH_CRON=*/5 * * * *

# ─── Storage ─────────────────────────────────────────────────────────────
SQLITE_PATH=./data/audit.db

# ─── Notifications ───────────────────────────────────────────────────────
# Comma-separated: slack,email,webhook,whatsapp
NOTIFY_CHANNELS=slack
# Slack incoming webhook
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SMTP
# ALERT_EMAIL=ops@grupowellness.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# Generic webhook
# NOTIFIER_WEBHOOK_URL=https://example.com/hook
# WhatsApp Business Cloud API
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_TEMPLATE_NAME=missed_call

# ─── Dashboard ───────────────────────────────────────────────────────────
DASHBOARD_PORT=3000
